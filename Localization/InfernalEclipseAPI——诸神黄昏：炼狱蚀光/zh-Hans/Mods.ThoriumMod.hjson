Items: {
	CapeoftheSurvivor: {
		DisplayName: 生存者披风
		Tooltip:
			'''
			“这款披风的结构旨在引导你度过艰难的日子”
			你随时间快速地获取至多15%伤害减免
			受击时会短暂地将此加成变为-10%伤害减免
			当此加成高于0%时，你会获得至多2点生命恢复
			'''
	}

