		}

		ForceFullXerocDialogue: {
			Label: 强制播放克希洛克的对话
			Tooltip: 当你开启或击败Boss Rush时，强制游戏播放克希洛克的对话，适用于多人游戏
		}

		SOTSThrowerToRogue: {
			Tooltip: 让来自Unofficial SOTS Bard, Thrower, and Healer模组的虚空+投掷伤害物品也被算作虚空+盗贼伤害物品
			Label: 融合盗贼伤害和虚空+投掷伤害
		}

		DisableBloodOrbPotions: {
			Tooltip: 禁用含有血珠的药水配方
			Label: 禁用血珠药水配方
		}

		PreventBossCheese: {
			Tooltip: 加入了一些机制，使得部分Boss无法被特殊方法轻松击杀
			Label: 防止逃课
		}

		DisableUnfinisedContent: {
			Label: 禁用未完成物品
			Tooltip: 禁用来自其他模组的未完成物品，以便玩家享受更完整的流程
		}

		DisableDuplicateContent: {
			Label: 禁用重复内容
			Tooltip: 禁用来自不同模组的重复物品
		}

		AdditonalVanillaBossAdjustments: {
			Label: 额外原版Boss调整
			Tooltip:
				'''
				小幅度调整了部分原版Boss的数值，让它们变得更有挑战性
				该设置不会移除诸神黄昏模式中为原版Boss添加的专属AI
				[c/FFFF00:《诸神黄昏：炼狱蚀光》整合包的平衡是以“启用”这个设置而展开的]
				'''
		}

		MergeCraftingTrees: {
			Label: 融合制作树
			Tooltip:
				'''
				将不同模组的相似物品制作树融合起来，并加入跨模组的制作材料
				[c/FFFF00:《诸神黄昏：炼狱蚀光》整合包的平衡是以“启用”这个设置而展开的]
				'''
		}

		BloodOrbPotionDuplication: {
			Label: 药水血珠复制
			Tooltip: 将药水的血珠配方修改为使用血珠复制的配方
		}

		ChanageWeaponClasses: {
