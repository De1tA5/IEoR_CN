	BloodPotion: 增加15%挖掘速度
	FrenzyPotion: 增加5%所有攻击速度
	FlowerCrown:
		'''
		降低10%所受伤害
		增加4点虚空恢复量和生命恢复速度
		在使用虚空值时，使用的30%虚空值会转化为生命值
		'''
	TravelBoot:
		'''
		增加5%移动速度
		奔跑加速度提升2%
		'''

	Nightmare: {
		Orig: 暴击会释放梦魇手臂，造成10%伤害并将敌人吸引到一起
		Rework:
			'''
			暴击会释放梦魇手臂，造成5%伤害并将敌人吸引到一起
			困难模式下伤害变为10%，且Boss不会被吸引
			'''
	}

	Helios: {
		Orig: 每次攻击命中都会造成烧焦，会永久增加3%伤害
		Nerf: 每次攻击命中都会造成烧焦，会永久增加1%伤害
	}

	Icosahedron: {
		Hellfire: {
			Orig: 暴击时会引起火焰爆裂，造成100%伤害
			Nerf: 暴击时会引起火焰爆裂，造成50%伤害
		}

		Borealis: {
			Orig: 暴击时会引起霜火爆裂，造成200%伤害
			Nerf: 暴击时会引起霜火爆裂，造成75%伤害
		}

		Cursed: {
			OrigCursed: 暴击时会释放诅咒雷，造成100%伤害
			NerfCursed: 暴击时会释放诅咒雷，造成75%伤害
			OrigOther: 暴击也会引起霜火或火焰爆裂，造成100%伤害
			NerfOther: 暴击也会引起霜火或火焰爆裂，造成75%伤害
		}

		Charms: {
			Orig: 暴击有概率引爆敌人，造成100%伤害
			Nerf: 暴击有概率引爆敌人，造成75%伤害
		}
	}

	DreadGreaves: {
		Orig: 增加20%移动速度
		Nerf: 增加9%移动速度
	}

	PlasmaShrimp: {
		Orig: 当超过40%魔力值时，魔法武器射出额外的，很烫的虾等离子体，造成50%伤害
		Nerf: 当超过40%魔力值时，魔法武器射出额外的，很烫的虾等离子体，造成25%伤害
	}

	ShatteredDreams: {
		Orig: 魔法武器会释放出一颗100%伤害的星星，但会消耗相当于其魔力消耗的10%虚空值
		Nerf:
			'''
			魔法武器会释放出一颗100%伤害的星星，但会消耗相当于其魔力消耗的10%虚空值
			一次只能释放3颗星星
			'''
	}

	OtherworldlyAmplifier:
		'''
		暴击最多额外造成8点额外伤害
		初始伤害加成为2点，并会随物品使用速度的降低而增加
		你的当前加成为{0}点
		'''
