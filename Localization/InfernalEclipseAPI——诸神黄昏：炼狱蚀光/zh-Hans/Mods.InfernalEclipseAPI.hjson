	BossRushTier6MusicBox: {
		Tooltip: 播放“Descent Of Divinities” 作者：psykomatic
		DisplayName: 音乐盒 (Boss Rush第六阶段)
	}

	NovaBomb: {
		DisplayName: 新星涡流
		Tooltip:
			'''
			引导旅者的秘力，释放造成大范围的爆炸
			右键可提前坍缩黑洞
			“放心吧维洛，我一个人就能搞定。”
			'''
