DiaryTooltip:
	'''
	[c/E3AF40:一本落款“星河”的神秘日记……]
	[c/BEBEBE:长按“左Shift”键以阅读日记]
	'''
BullyingTooltip:
	'''
	每有一个未使用的召唤栏，非召唤伤害提升2%
	每有一个已使用的召唤栏，召唤伤害降低10%
	鞭子现在将受益于近战伤害加成，而不是召唤伤害加成
	鞭子伤害提升25%
	[c/E3AF40:一张附带芯片的纸条，由迪伦设计]
	[c/BEBEBE:按住"左Shift"以阅读便笺背面的文字]
	'''

Configs: {
	InfernalConfig: {
		WrathoftheGodsBossesInBossRush: {
			Tooltip: 为Boss Rush添加XG-07 玛尔斯、虚无化身和无名光神
			Label: Boss Rush添加众神之怒Boss
		}

		BetsyInBossRush: {
			Tooltip: 为Boss Rush添加双足翼龙 - 当前存在bug
			Label: Boss Rush添加双足翼龙
		}

		DreadnautillusInBossRush: {
			Tooltip: 为Boss Rush添加恐惧鹦鹉螺
			Label: Boss Rush添加恐惧鹦鹉螺
		}

		Headers: {
			BossRushChanges: Boss Rush调整
			BalanceChanges: 模组平衡修改
			Miscellaneous: 融合
			MultiplayerAdjustments: 多人游戏调整
			Main: 主要
			Secret: 秘密设置
			Music: 音乐设置
			CompatibilityChanges: 兼容性修改
		}

		ThoriumBalanceChangess: {
			Tooltip:
				'''
				修改了瑟银及其附属的部分物品以匹配灾厄平衡性
				[c/FFFF00:《诸神黄昏：炼狱蚀光》整合包的平衡是以“启用”这个设置而展开的]
				'''
			Label: 瑟银平衡修改
		}

		CalamityRecipeTweaks: {
			Tooltip: 修改了灾厄的部分配方并移除了大部分灾厄原版物品配方
			Label: 灾厄配方修改
		}

		CalamityBalanceChanges: {
			Tooltip:
				'''
				对部分数值过低或过高的灾厄及其附属的物品进行调整  
				同时修改部分跨模组的合成配方以保持平衡
				[c/FFFF00:《诸神黄昏：炼狱蚀光》整合包的平衡是以“启用”这个设置而展开的]
				'''
			Label: 灾厄平衡修改
		}

		BossKillCheckOnOres: {
			Tooltip:
				'''
				修改了部分物品，使其在达到预期游戏阶段之前无法获得
				直到你击败指定的Boss前，阻止你挖掘特定的矿石以及物品
				[c/FFFF00:《诸神黄昏：炼狱蚀光》整合包的平衡是以“启用”这个设置而展开的]
				'''
			Label: 保持灾厄模组的游戏阶段进度
		}

		VanillaBalanceChanges: {
			Tooltip:
				'''
				修改了一些原版物品以匹配灾厄平衡性
				[c/FFFF00:《诸神黄昏：炼狱蚀光》整合包的平衡是以“启用”这个设置而展开的]
				'''
			Label: 原版平衡修改
		}

		DisplayName: 主要配置选项

		TerraBladeBossInBossRush: {
			Tooltip: 为Boss Rush添加泰拉刃，你的镜像
			Label: Boss Rush添加泰拉刃
		}

		InfernumModeForced: {
			Tooltip:
				'''
				锁定灾厄难度选择UI，即便在非Boss战时也无法调整
				请务必在启用此配置前先设定好难度
				适用于不希望玩家随意更改难度的服务器
