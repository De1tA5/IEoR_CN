	BossRushTierNamelessMusicBox: {
		Tooltip: 播放“TWISTED GARDEN [Remix]” 作者：Kuudray
		DisplayName: 音乐盒 (Boss Rush第???阶段)
	}

	BossRushEncoreMusicBox: {
		Tooltip: 播放“Ensemble of Fools (Encore Mix)” 作者：CDMusic
		DisplayName: 音乐盒 (Boss Rush再献)
	}

	StellarSabre: {
		DisplayName: 星火军刀
		Tooltip: ""

		Progression: {
			WoF:
				'''
				击败地狱守护者以获得更多力量……
				尚未获得额外力量……
				'''
			Mechs:
				'''
				随着血肉墙被击败，此剑可发射额外的星辰
				击败机械造物以获得更多力量……
				'''
			Plantera:
				'''
				击败嘉登的机械装置后，它现在会附加[cbuff:CalamityMod/AstralInfectionDebuff]减益
				击败丛林守护者以获得更多力量……
				'''
			Golem:
				'''
				击败世纪之花后，星辰在命中时会分裂
				击败神庙的蜥蜴造物以获得更多力量……
				'''
			Cultist:
				'''
				击败石巨人后，星辰会自动追踪敌人
				星辰现在将会分裂
				击败古代邪教领袖以获得更多力量……
				'''
			MoonLord:
				'''
				击败拜月教邪教徒后，星辰会在一段时间后爆炸
				击败古神的邪异残躯以获得更多力量……
				'''
			Full:
				'''
				星火军刀已完全苏醒，所有能力都被大幅强化
				武器的最大威能解禁！
				'''
		}

		Lore: “即便历经这一切，仍有一人——赞达尔，始终不愿攻击……”
	}

	ExoSights: {
		DisplayName: 星流视域
		Tooltip: ""
		SOTSBardHealerTooltip:
			'''
			暴击率提高15%，无法与下位饰品叠加
			暴击最多额外造成40点伤害，并有概率引爆敌人，造成75%额外伤害
			初始伤害加成为15点，并会随物品使用速度的降低而增加
			你的当前加成为{0}点
			暴击汲取生命，恢复虚空值，回复魔力，并返还灵感值
