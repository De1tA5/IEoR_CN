	Lycanroc: {
		DisplayName: 寒语夜啸
		Tooltip: ""

		Progression: {
			WoF:
				'''
				击败地狱守护者以获得更多力量……
				尚未获得额外力量……
				'''
			Mechs:
				'''
				随着血肉墙被击败，该武器发射的子弹可造成[cbuff:CalamityMod/Crumbling]效果
				击败机械造物以获得更多力量……
				'''
			Plantera:
				'''
				击败嘉登的机器装置后，该武器将普通子弹转换为高速子弹
				击败丛林守护者以获得更多力量……
				'''
			Golem:
				'''
				击败世纪之花后，你的怒火使该武器射速大幅增加
				击败神庙的蜥蜴造物以获得更多力量……
				'''
			Cultist:
				'''
				击败石巨人后，你开启肾上腺素时将一定会暴击
				击败古代邪教领袖以获得更多力量……
				'''
			MoonLord:
				'''
				击败拜月教邪教徒后，该武器现在有概率触发超级暴击
				击败古神的邪异残躯以获得更多力量……
				'''
			Full: 寒语夜啸已苏醒，最大威能解禁！
		}

		Lore: “你打算做什么？杀了我？”
	}

	CelestialIllumination: {
		DisplayName: 星界启明
		Tooltip: ""

		Progression: {
			Deus:
				'''
				击败古神的邪异残躯以获得更多力量……
				尚未获得额外力量……
				'''
			MoonLord:
				'''
				击败月亮领主后，你的星辰变得更快
				击败亵渎之炎的守护者以获得更多力量……
				'''
			Providence:
				'''
				击败亵渎天神后，你的攻击会施加[cbuff:CalamityMod/HolyFlames]减益
				击败噬魂集合体以获得更多力量……
				'''
			Polterghast:
				'''
				击败噬魂幽花后，你可以发射一道星体光束
				击败噬神凶灵以获得更多力量……
				'''
			DoG:
				'''
				击败神明吞噬者后，你的星辰获得追踪
				击败光辉之凰以获得更多力量……
				'''
			Full: 星界启明已苏醒，最大威能解禁！
			ProfanedGuardians:
				'''
				击败亵渎守卫后，你可以发射一道星体光束
				击败神怒之焰以获得更多力量……
				'''
			Sentinels:
				'''
				击败神之仆从后，你的星体光束持续时间更久
				击败噬神凶灵以获得更多力量……
				'''
		}

		Lore: 由身负星界印记之人铸就的最终之书……
	}

