		}

		EnableInterlude4: {
			Label: 插曲4
			Tooltip:
				'''
				切换启用第4插曲的播放
				此插曲会在星流巨械与至尊灾厄都被击败后播放
				该曲目播放时会覆盖“Their Fabricator”与“Acceptance”两首插曲
				'''
